# ============================================================
# 工具中心全局配置
# ============================================================
TOOL_HUB_UPLOAD_DIR=./uploads          # 上传文件存储目录
TOOL_HUB_MAX_UPLOAD_SIZE=52428800      # 最大上传文件大小 (50MB)

# ============================================================
# MIP 海关清关工具配置
# ============================================================
MIP_BASE_URL=https://mypost.mn
MIP_ACCESS_TOKEN=
MIP_ACCESS_TOKEN_TEST=
MIP_ACCESS_TOKEN_PROD=
MIP_TIMEOUT=30.0
MIP_ENV=production

# ============================================================
# Temu 网关工具配置
# ============================================================
TEMU_GATEWAY_URL=https://testwebhook.staritgp.com/gateway
# ============================================================
# PDD 集运下单工具配置
# ============================================================
PDD_GATEWAY_URL=https://testwebhook.staritgp.com/pdd-gateway
PDD_CLIENT_SECRET=
PDD_APP_ID=KIMIGO_MN
PDD_WAREHOUSE_CODE=KIMIGO
# ============================================================
# 推送重量工具配置（生产环境，谨慎操作）
# ============================================================
PUSH_WEIGHT_TMS_HOST=https://tms.prod.kimigoshop.com
PUSH_WEIGHT_TMS_USER=
PUSH_WEIGHT_TMS_PASSWORD=
PUSH_WEIGHT_DB_HOST=
PUSH_WEIGHT_DB_PORT=3306
PUSH_WEIGHT_DB_USER=
PUSH_WEIGHT_DB_PASSWORD=
PUSH_WEIGHT_DB_NAME=kysmallbox
PUSH_WEIGHT_PUSH_INTERVAL=1.0

# ============================================================
# 财务系统工具配置（TMS 测试环境）
# ============================================================
FINANCE_TMS_HOST=https://tms-qa.kimigoshop.com
FINANCE_TMS_USER=
FINANCE_TMS_PASSWORD=
FINANCE_TIMEOUT=30.0
